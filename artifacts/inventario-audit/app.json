{
  "expo": {
    "name": "Auditoría de Inventario",
    "slug": "inventario-audit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "inventario-audit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "La app necesita acceso a la cámara para escanear códigos de barras.",
        "NSPhotoLibraryUsageDescription": "La app necesita acceso a las fotos para importar archivos."
      }
    },
    "android": {
      "package": "com.auditstock.inventario",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "La app necesita la cámara para escanear códigos de barras."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/82653458-4336-45d4-9b1d-a3c6410411ca",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "82653458-4336-45d4-9b1d-a3c6410411ca"
      }
    },
    "owner": "okassaki"
  }
}
