{
  "expo": {
    "name": "Auditoría de Inventario",
    "slug": "inventario-audit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "inventario-audit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "La app necesita acceso a la cámara para escanear códigos y hacer video llamadas.",
        "NSPhotoLibraryUsageDescription": "La app necesita acceso a las fotos para importar archivos.",
        "NSMicrophoneUsageDescription": "La app necesita el micrófono para llamadas de audio y video."
      }
    },
    "android": {
      "package": "com.auditstock.inventario",
      "googleServicesFile": "./google-services.json",
      "versionCode": 28,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CONTACTS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "La app necesita la cámara para escanear códigos de barras y video llamadas."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00D4FF",
          "androidMode": "default",
          "androidCollapsedTitle": "AuditStock"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "La app necesita acceso a tus contactos para enviarlos en el chat."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "82653458-4336-45d4-9b1d-a3c6410411ca"
      }
    },
    "owner": "okassaki"
  }
}
